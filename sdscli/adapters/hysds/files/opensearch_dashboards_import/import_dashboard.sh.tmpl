#!/bin/bash
./wait-for-it.sh {{GRQ_FQDN}}:5601 -t 120

# Sleeping to give time for kibana to start up
# sleep 60

# job and worker metrics
curl -f -XDELETE -H 'Content-Type: application/json' -H 'securitytenant: global' -H 'osd-xsrf: true' 'https://{{MOZART_FQDN}}/metrics/api/saved_objects/index-pattern/logstash-*'
curl -f -XPOST -H 'Content-Type: application/json' -H 'securitytenant: global' -H 'osd-xsrf: true' 'https://{{MOZART_FQDN}}/metrics/api/saved_objects/index-pattern/logstash-*' '-d{"attributes":{"title":"logstash-*","timeFieldName":"@timestamp"}}'
curl -XPOST -H 'Content-Type: application/json' -H 'securitytenant: global' -H 'osd-xsrf: true' 'https://{{MOZART_FQDN}}/metrics/api/opensearch-dashboards/settings/defaultIndex' -d'{"value": "logstash-*"}'
curl -XPOST https://{{MOZART_FQDN}}/metrics/api/opensearch-dashboards/dashboards/import -H 'securitytenant: global' -H 'osd-xsrf:true' -H 'Content-type:application/json' -d @job-dashboards.json
curl -XPOST https://{{MOZART_FQDN}}/metrics/api/opensearch-dashboards/dashboards/import -H 'securitytenant: global' -H 'osd-xsrf:true' -H 'Content-type:application/json' -d @worker-dashboards.json

# SDSWatch
curl -f -XDELETE -H 'securitytenant: global' -H 'Content-Type: application/json' -H 'osd-xsrf: true' 'https://{{MOZART_FQDN}}/metrics/api/saved_objects/index-pattern/sdswatch-*'
curl -f -XPOST -H 'securitytenant: global' -H 'Content-Type: application/json' -H 'osd-xsrf: true' 'https://{{MOZART_FQDN}}/metrics/api/saved_objects/index-pattern/sdswatch-*' '-d{"attributes":{"title":"sdswatch-*","timeFieldName":"sdswatch_timestamp"}}'
curl -XPOST https://{{MOZART_FQDN}}/metrics/api/opensearch-dashboards/dashboards/import -H 'securitytenant: global' -H 'osd-xsrf:true' -H 'Content-type:application/json' -d @sdswatch-dashboards.json
